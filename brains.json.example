{
  "coder": {
    "label": "Coder — local GPU LLM",
    "base_url": "http://localhost:8084/v1",
    "model": "<YOUR_MODEL_NAME>",
    "available": true
  },
  "local": {
    "label": "Local — desktop router (loaded model)",
    "base_url": "http://<HOST>:8081/v1",
    "model": "auto",
    "available": true
  },
  "hermes": {
    "label": "Hermes",
    "base_url": "http://localhost:8087/v1",
    "model": "auto",
    "api_key_file": "<PATH>/.hermes/shim.env",
    "api_key_var": "HERMES_SHIM_TOKEN",
    "available": true
  },
  "claude": {
    "label": "Claude",
    "available": false,
    "note": "pending — no responses-api endpoint"
  }
}
