<!doctype html>
<meta charset="utf-8">
<script>
  // Applied synchronously, before first paint, to avoid a flash of the wrong theme.
  // Only a built-in id is safe to apply this early (custom themes need their
  // stylesheet fetched first); anything else falls back to the default and the
  // boot logic in the main script upgrades it once themes.json has loaded.
  (function () {
    var saved = null;
    try { saved = localStorage.getItem("va-theme"); } catch {}
    var builtins = ["editorial", "console", "hifi"];
    document.documentElement.setAttribute("data-theme", builtins.indexOf(saved) !== -1 ? saved : "editorial");
    document.documentElement.setAttribute("data-mood", "neutral");
  })();
</script>
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
<title>Voice Client</title>
<link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'><circle cx='12' cy='12' r='11' fill='%230a0a12'/><path d='M12 15a3 3 0 0 0 3-3V6a3 3 0 0 0-6 0v6a3 3 0 0 0 3 3Z' fill='%2322d3ee'/><path d='M19 11a1 1 0 1 0-2 0 5 5 0 0 1-10 0 1 1 0 1 0-2 0 7 7 0 0 0 6 6.93V21H9a1 1 0 1 0 0 2h6a1 1 0 1 0 0-2h-2v-3.07A7 7 0 0 0 19 11Z' fill='%2322d3ee'/></svg>">
<!-- Only consumed by the lazy, desktop-only avatar module (avatar/avatar.mjs);
     must be declared before any module script/dynamic import runs. -->
<script type="importmap">
{
  "imports": {
    "three": "./avatar/vendor/three/three.module.js",
    "three/addons/": "./avatar/vendor/three/addons/"
  }
}
</script>
<style>
  /* ── Design tokens ──────────────────────────────────────────────────
     Every theme (built-in or custom) redefines this exact set of custom
     properties under a [data-theme="<id>"] selector. Nothing outside this
     token layer + the small per-theme override blocks below should ever
     hardcode a color, font stack, radius or shadow — that's what keeps
     the three built-ins (and any future custom theme) CSS-only. See
     themes/THEME-SPEC.md for the authoritative token reference. */
  :root {
    --bg: #F5F5F0;
    --surface: #F5F5F0;
    --surface-2: #EFEBE0;
    --border: rgba(26,26,26,0.14);
    --text: #1A1A1A;
    --text-muted: rgba(26,26,26,0.52);
    --accent: #C1440E;
    --accent-2: #6b6b52;
    --rec: #C1272D;
    --ok: #2f9e63;
    --warn: #c98a1a;
    --bad: #b3261e;
    --radius: 3px;
    --radius-sm: 2px;
    --font-body: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    --font-display: 'Iowan Old Style', 'Palatino Linotype', Palatino, Georgia, serif;
    --font-mono: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    --tracking-label: 0.12em;
    --shadow-card: none;
    --ptt-shadow-idle: 0 0 0 1px var(--border);
    --ptt-shadow-rec: 0 0 0 1px var(--rec), 0 0 18px color-mix(in srgb, var(--rec) 30%, transparent);
    --ptt-size: 84px;
    --ptt-radius: 50%;
  }

  /* ── Editorial (default): warm paper, ink type, the reply IS the interface ── */
  [data-theme="editorial"] {
    --bg: #F5F5F0;
    --surface: #F5F5F0;
    --surface-2: #EFEBE0;
    --border: rgba(26,26,26,0.14);
    --text: #1A1A1A;
    --text-muted: rgba(26,26,26,0.52);
    --accent: #C1440E;
    --accent-2: #6b6b52;
    --rec: #C1272D;
    --ok: #2f9e63;
    --warn: #c98a1a;
    --bad: #b3261e;
    --radius: 3px;
    --radius-sm: 2px;
    --font-body: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    --font-display: 'Iowan Old Style', 'Palatino Linotype', Palatino, Georgia, serif;
    --font-mono: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    --tracking-label: 0.12em;
    --shadow-card: none;
    --ptt-shadow-idle: 0 0 0 1px var(--border);
    --ptt-shadow-rec: 0 0 0 1px var(--rec), 0 0 18px color-mix(in srgb, var(--rec) 30%, transparent);
    --ptt-size: 84px;
    --ptt-radius: 50%;
  }

  /* ── Console: Braun/Teenage Engineering, light matte body, one bright PTT ── */
  [data-theme="console"] {
    --bg: #E7E3D8;
    --surface: #EFEBE0;
    --surface-2: #DDD8C9;
    --border: rgba(30,28,22,0.16);
    --text: #1E1C16;
    --text-muted: rgba(30,28,22,0.56);
    --accent: #E8590C;
    --accent-2: #4A4A42;
    --rec: #D93025;
    --ok: #3C8C5B;
    --warn: #C98A1A;
    --bad: #C0392B;
    --radius: 8px;
    --radius-sm: 6px;
    --font-body: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    --font-display: ui-monospace, "Space Mono", SFMono-Regular, Menlo, Consolas, monospace;
    --font-mono: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    --tracking-label: 0.08em;
    --shadow-card: 0 1px 2px rgba(30,28,22,0.08);
    --ptt-shadow-idle: 0 2px 10px rgba(30,28,22,0.18), inset 0 1px 0 rgba(255,255,255,0.4);
    --ptt-shadow-rec: 0 0 0 3px color-mix(in srgb, var(--rec) 35%, transparent), 0 2px 12px rgba(30,28,22,0.28);
    --ptt-size: 136px;
    --ptt-radius: 50%;
  }

  /* ── Hi-Fi: 1970s amplifier, dark chassis, VU meters, machined key PTT ── */
  [data-theme="hifi"] {
    --bg: #17140F;
    --surface: #211D17;
    --surface-2: #2A251D;
    --border: rgba(255,247,224,0.09);
    --text: #F2E9D8;
    --text-muted: rgba(242,233,216,0.52);
    --accent: #EA6B1E;
    --accent-2: #E3D9A8;
    --rec: #FF5F52;
    --ok: #7CC98A;
    --warn: #E8B339;
    --bad: #FF6B5E;
    --radius: 10px;
    --radius-sm: 6px;
    --font-body: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    --font-display: ui-monospace, "Space Mono", SFMono-Regular, Menlo, Consolas, monospace;
    --font-mono: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    --tracking-label: 0.1em;
    --shadow-card: inset 0 1px 0 rgba(255,255,255,0.04), 0 2px 6px rgba(0,0,0,0.4);
    --ptt-shadow-idle: 0 4px 14px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.08);
    --ptt-shadow-rec: 0 0 0 1px color-mix(in srgb, var(--rec) 60%, transparent), 0 0 24px color-mix(in srgb, var(--rec) 45%, transparent), 0 4px 14px rgba(0,0,0,0.5);
    --ptt-size: 120px;
    --ptt-radius: 22px;
  }

  * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
  html, body { margin: 0; height: 100%; }
  body {
    background: var(--bg);
    color: var(--text);
    font: 16px/1.5 var(--font-body);
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 16px;
    min-height: 100%;
    transition: background 0.2s ease, color 0.2s ease;
  }
  [data-theme="console"] body {
    background: linear-gradient(135deg, var(--bg) 0%, color-mix(in srgb, var(--bg) 90%, white) 100%);
  }
  [data-theme="hifi"] body {
    background: linear-gradient(160deg, color-mix(in srgb, var(--bg) 96%, white) 0%, var(--bg) 55%),
                repeating-linear-gradient(0deg, rgba(255,255,255,0.015) 0px, rgba(255,255,255,0.015) 1px, transparent 1px, transparent 2px);
  }
  button, input, select, textarea { font-family: inherit; }
  button:focus-visible, [tabindex]:focus-visible, input:focus-visible, select:focus-visible, textarea:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  header {
    width: 100%;
    max-width: 640px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 16px;
  }
  h1 { font-size: 17px; margin: 0; font-weight: 700; letter-spacing: 0.01em; font-family: var(--font-body); }
  [data-theme="console"] h1, [data-theme="hifi"] h1 {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-family: var(--font-mono);
    font-size: 14px;
  }
  #status {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: 7px;
    white-space: nowrap;
  }
  #dot {
    width: 9px; height: 9px; border-radius: 50%;
    background: var(--text-muted);
    flex: 0 0 auto;
    box-shadow: 0 0 0 rgba(0,0,0,0);
  }
  #dot.connected { background: var(--ok); box-shadow: 0 0 10px color-mix(in srgb, var(--ok) 70%, transparent); }
  #dot.connecting { background: var(--warn); box-shadow: 0 0 10px color-mix(in srgb, var(--warn) 70%, transparent); }
  #dot.error { background: var(--bad); box-shadow: 0 0 10px color-mix(in srgb, var(--bad) 70%, transparent); }
  #statusText.shimmer {
    background: linear-gradient(90deg, var(--text-muted) 0%, var(--text) 50%, var(--text-muted) 100%);
    background-size: 200% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    animation: shimmer 1.6s linear infinite;
  }
  @keyframes shimmer {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  /* ── Dual layout: mobile single column / desktop 3-zone grid ───────── */
  #contentGrid {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1;
  }
  #historyRail, #sessionRail { display: none; }
  #avatarPane { display: none; }

  main {
    width: 100%;
    max-width: 640px;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 14px;
    align-items: center;
  }
  .card {
    width: 100%;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 13px 15px;
    box-shadow: var(--shadow-card);
    transition: box-shadow 0.25s ease, border-color 0.25s ease, background 0.2s ease;
  }
  .card .label {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--text-muted);
    margin-bottom: 6px;
    font-family: var(--font-body);
  }
  .card .body { font-size: 16px; min-height: 24px; word-wrap: break-word; }
  #assistantText .body { color: var(--accent); }
  #assistantText.speaking {
    border-color: color-mix(in srgb, var(--accent) 55%, var(--border));
    box-shadow: var(--shadow-card), 0 0 0 1px color-mix(in srgb, var(--accent) 25%, transparent), 0 0 20px color-mix(in srgb, var(--accent) 18%, transparent);
  }

  @media (min-width: 1024px) {
    header { max-width: 1240px; }
    #contentGrid {
      display: grid;
      grid-template-columns: 280px minmax(0, 640px) 280px;
      column-gap: 32px;
      align-items: start;
      max-width: 1240px;
      margin: 0 auto;
    }
    #historyRail, #sessionRail { display: flex; flex-direction: column; }
    main { max-width: none; }

    #transcript .body {
      font-family: var(--font-display);
      font-style: italic;
      font-size: 19px;
      color: var(--text-muted);
    }
    #assistantText .body {
      font-family: var(--font-display);
      font-size: 40px;
      line-height: 1.08;
      letter-spacing: -0.01em;
    }
    [data-theme="editorial"] main #assistantText {
      border: none;
      background: transparent;
      box-shadow: none;
      padding: 0;
    }
    [data-theme="editorial"] main #assistantText.speaking { box-shadow: none; }

    /* ── Avatar pane: lazy TalkingHead render target, top of the center
       column, above the transcript/assistant cards. Desktop-only like the
       rails — mobile never sees it (base rule above keeps it display:none).
       #avatarToggle collapses/expands via height, not display, so the
       chevron stays reachable; the glow reads --level for a subtle live-mic
       pulse (see THEME-SPEC.md's --level bus), no JS needed for that part. */
    #avatarPane {
      display: flex;
      flex-direction: column;
      position: relative;
      width: 100%;
      height: 300px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow-card), 0 0 0 1px color-mix(in srgb, var(--accent) calc(var(--level, 0) * 35%), transparent);
      overflow: hidden;
      transition: height 0.25s ease, box-shadow 0.15s ease;
    }
    #avatarPane.collapsed { height: 40px; }
    #avatarMount { flex: 1; min-height: 0; }
    #avatarMount canvas { display: block; width: 100%; height: 100%; }
    #avatarPane.collapsed #avatarMount,
    #avatarPane.collapsed #avatarFallback { display: none; }
    #avatarFallback {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 12px;
      font-family: var(--font-mono);
      color: var(--text-muted);
    }
    #avatarFallback[hidden] { display: none; }
    #avatarToggle {
      position: absolute;
      top: 8px;
      right: 8px;
      z-index: 1;
      width: 28px;
      height: 28px;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0;
      background: var(--surface-2);
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      color: var(--text-muted);
      cursor: pointer;
    }
    #avatarToggle svg { width: 16px; height: 16px; transition: transform 0.2s ease; }
    #avatarPane.collapsed #avatarToggle svg { transform: rotate(180deg); }
    @media (prefers-reduced-motion: reduce) {
      #avatarPane, #avatarToggle svg { transition: none; }
    }
  }

  /* ── Rails (desktop only) ───────────────────────────────────────────── */
  #historyRail, #sessionRail {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 20px;
    gap: 4px;
    max-height: calc(100vh - 120px);
    overflow-y: auto;
  }
  #historyRail .label, #sessionRail .label {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--text-muted);
    margin-bottom: 12px;
    font-family: var(--font-body);
  }
  .historyEntry { padding: 10px 0; border-bottom: 1px solid var(--border); }
  .historyEntry:last-child { border-bottom: none; }
  .historyTime { font-family: var(--font-mono); font-size: 10px; color: var(--text-muted); opacity: 0.7; margin-bottom: 4px; }
  .historyUser { font-size: 12px; font-style: italic; color: var(--text-muted); margin-bottom: 3px; line-height: 1.3; }
  .historyAssistant { font-size: 13px; color: var(--text); line-height: 1.35; }

  .sessionRow {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 10px;
    padding: 9px 0;
    border-bottom: 1px solid var(--border);
    font-size: 12px;
  }
  .sessionKey {
    color: var(--text-muted);
    text-transform: uppercase;
    font-size: 10px;
    letter-spacing: var(--tracking-label);
    font-family: var(--font-mono);
    flex: 0 0 auto;
  }
  .sessionVal { color: var(--text); font-family: var(--font-mono); text-align: right; word-break: break-word; }
  .sessionPersona { margin-top: 16px; }
  #sessionPersonaSnippet { font-size: 12px; font-style: italic; color: var(--text-muted); line-height: 1.45; }

  /* ── Cockpit: quest card (top of #sessionRail, desktop only) ─────────
     Pure render from the latest cockpit_state snapshot — see renderCockpit()
     in the script below. Hidden entirely when idle with no open permissions
     so the rail looks exactly like it did before this feature existed. */
  #questCard { margin-bottom: 16px; padding-bottom: 14px; border-bottom: 1px solid var(--border); }
  #questCard[hidden] { display: none; }
  .questHeader {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--text-muted);
    margin-bottom: 8px;
    font-family: var(--font-body);
  }
  .questTaskText {
    font-size: 13px;
    color: var(--text);
    line-height: 1.35;
    margin-bottom: 6px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .questStatusLine {
    font-size: 11px;
    color: var(--text-muted);
    font-family: var(--font-mono);
    margin-bottom: 8px;
  }
  .questUnreachable {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--bad);
    margin-bottom: 8px;
  }
  .questUnreachable[hidden] { display: none; }
  .questSteps {
    max-height: 180px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 5px;
    margin-bottom: 8px;
  }
  .questStep { font-size: 11px; line-height: 1.35; display: flex; gap: 6px; }
  .questStepRole {
    flex: 0 0 auto;
    color: var(--text-muted);
    font-family: var(--font-mono);
    text-transform: uppercase;
    font-size: 10px;
  }
  .questStepText { color: var(--text); word-break: break-word; }
  .questResult {
    font-size: 12px;
    color: var(--text);
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 8px;
    white-space: pre-wrap;
    word-break: break-word;
  }
  .questResult[hidden] { display: none; }
  #questCard[data-cockpit-status="error"] .questResult { border-color: color-mix(in srgb, var(--bad) 45%, var(--border)); color: var(--bad); }
  #questCard[data-cockpit-status="running"] .questStatusLine,
  #questCard[data-cockpit-status="sent"] .questStatusLine { color: var(--accent); }

  /* ── Cockpit: approval gate banner (fixed, ALL viewports — approvals are
     latency-critical and must be reachable on mobile too) ─────────────── */
  #gateBanner {
    position: fixed;
    top: 12px;
    left: 50%;
    transform: translateX(-50%);
    width: min(520px, calc(100% - 24px));
    z-index: 20;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-card), 0 4px 20px rgba(0, 0, 0, 0.25);
    padding: 12px 14px;
  }
  #gateBanner[hidden] { display: none; }
  .gateBannerInner { display: flex; flex-direction: column; gap: 8px; }
  .gateDesc { font-size: 13px; color: var(--text); line-height: 1.35; }
  .gateMore { font-size: 11px; color: var(--text-muted); }
  .gateMore:empty { display: none; }
  .gateControls { display: flex; gap: 10px; align-items: center; }
  .gateDenyBtn {
    flex: 0 0 auto;
    min-height: 44px;
    padding: 0 16px;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--bg);
    color: var(--bad);
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
  }
  .gateDenyBtn:hover { background: var(--border); }
  .gateDenyBtn:disabled { opacity: 0.5; cursor: not-allowed; }
  .gateHold {
    flex: 1 1 auto;
    position: relative;
    min-height: 44px;
    border: 1px solid var(--accent);
    border-radius: var(--radius-sm);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    touch-action: none;
    -webkit-user-select: none;
    user-select: none;
  }
  .gateHold[aria-disabled="true"] { opacity: 0.5; cursor: not-allowed; pointer-events: none; }
  .gateHoldFill {
    position: absolute;
    inset: 0;
    width: calc(var(--hold-progress, 0) * 100%);
    background: color-mix(in srgb, var(--accent) 35%, transparent);
    transition: width 0.05s linear;
  }
  .gateHoldLabel {
    position: relative;
    z-index: 1;
    font-size: 13px;
    font-weight: 600;
    color: var(--accent);
  }
  @media (prefers-reduced-motion: reduce) {
    .gateHoldFill { transition: none; }
  }

  /* ── Themer (settings drawer, top section) ──────────────────────────── */
  #themeSwatches { display: flex; gap: 10px; flex-wrap: wrap; margin: 0 0 4px; }
  .themeSwatch {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    border-radius: 8px;
    min-width: 44px;
  }
  .themeSwatch:hover { background: var(--bg); }
  .swatchDot { width: 28px; height: 28px; border-radius: 50%; border: 1px solid var(--border); }
  .themeSwatch.active .swatchDot { box-shadow: 0 0 0 2px var(--surface), 0 0 0 4px var(--accent); }
  .themeSwatch .swatchName { font-size: 10px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.04em; }

  /* ── PTT orb ─────────────────────────────────────────────────────── */
  #pttWrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    margin-top: auto;
    padding-top: 6px;
  }
  #ptt {
    -webkit-user-select: none; user-select: none;
    touch-action: none;
    position: relative;
    width: var(--ptt-size);
    height: var(--ptt-size);
    border: none;
    border-radius: var(--ptt-radius);
    background: radial-gradient(circle at 35% 30%, color-mix(in srgb, var(--accent) 35%, var(--surface)), var(--surface) 70%);
    color: var(--accent);
    box-shadow: var(--ptt-shadow-idle);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.12s, box-shadow 0.12s, transform 0.08s, color 0.12s;
  }
  #ptt:active { transform: scale(0.97); }
  #ptt:disabled {
    background: var(--surface);
    color: var(--text-muted);
    box-shadow: 0 0 0 1px var(--border);
    cursor: not-allowed;
  }
  #ptt.recording {
    background: radial-gradient(circle at 35% 30%, color-mix(in srgb, var(--rec) 45%, var(--surface)), var(--surface) 70%);
    color: var(--rec);
    box-shadow: var(--ptt-shadow-rec);
  }
  .pttIcon { width: calc(var(--ptt-size) * 0.36); height: calc(var(--ptt-size) * 0.36); position: relative; z-index: 1; }
  .pttPulse {
    position: absolute;
    inset: 0;
    border-radius: var(--ptt-radius);
    border: 2px solid var(--rec);
    opacity: 0;
    pointer-events: none;
  }
  #ptt.recording .pttPulse {
    animation: pttPulse 1.4s ease-out infinite;
  }
  @keyframes pttPulse {
    0% { transform: scale(1); opacity: 0.55; }
    100% { transform: scale(1.65); opacity: 0; }
  }
  #pttCaption {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.03em;
    color: var(--text-muted);
    min-height: 18px;
    text-align: center;
  }

  /* ── Waveform ────────────────────────────────────────────────────── */
  .waveform {
    --level: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 4px;
    height: 22px;
    width: 100%;
    max-width: 220px;
  }
  .wbar {
    flex: 1 1 0;
    max-width: 6px;
    height: 100%;
    border-radius: 3px;
    background: var(--accent);
    opacity: 0.85;
    transform: scaleY(0.08);
    transform-origin: center;
    transition: transform 0.09s ease-out;
  }
  [data-theme="editorial"] .wbar { max-width: 3px; opacity: 0.7; }
  [data-theme="console"] .wbar, [data-theme="hifi"] .wbar { border-radius: 1px; max-width: 8px; }
  #ptt.recording ~ #waveform .wbar { background: var(--rec); }

  /* ── Theme-fidelity mount points ─────────────────────────────────────
     Inert, empty, display:none by default. Themes opt in with scoped
     [data-theme="…"] rules; every other theme (editorial + custom CSS
     themes) never references these selectors, so nothing changes for them.
     #meterChrome  — VU-meter / segment-meter chrome, sibling of .waveform,
                     holds empty .meterFace / .meterNeedle / .meterTicks.
     .panelFrame   — one inert div appended as the last child of each
                     .card, of #historyRail, of #sessionRail, and of
                     #settingsPanel — for frames/tape/screws/window-chrome.
     #pttDeco      — one inert span inside #ptt (after .pttPulse, before
                     .pttIcon) — for keycap slots, recessed rings, sigils.
                     Holds 8 inert <i> children so a theme can build a
                     CSS-only 3D polyhedron (transform-style: preserve-3d
                     on #pttDeco itself, each <i> a face) with no DOM changes.
     #fxBack       — one inert div, first child of body, position:fixed
                     full-viewport, behind all content — a living-background
                     layer. Pairs with the static `#vaMist` SVG filter (in
                     the inert 0×0 <svg> right before it) for a CSS-only
                     "void mist" texture: feTurbulence + feDisplacementMap
                     + feGaussianBlur, referenced via `filter: url(#vaMist)`.
     #bannerMount  — one inert div between header and #contentGrid, full
                     width — for a notification/banner treatment.
     .statCol      — two inert divs (#statColL, #statColR) inside #pttWrap,
                     flanking #ptt — for side stat-bar/meter chrome. Themes
                     typically show these desktop-only (gate mobile off via
                     a min-width media query) and position them with
                     `position: absolute` off a `position: relative` they
                     set on #pttWrap in their own scoped rule.
  ------------------------------------------------------------------- */
  #meterChrome, .panelFrame, #pttDeco, #fxBack, #bannerMount, .statCol { display: none; pointer-events: none; }

  .hint { font-size: 12px; color: var(--text-muted); text-align: center; }

  /* ── Diagnostics ─────────────────────────────────────────────────── */
  .diagToggle {
    background: none;
    border: none;
    color: var(--text-muted);
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    cursor: pointer;
    padding: 6px;
    align-self: center;
  }
  .diagToggle:hover { color: var(--text); }
  #log {
    font-size: 12px;
    color: var(--text-muted);
    max-width: 640px;
    width: 100%;
    white-space: pre-wrap;
    word-break: break-word;
    max-height: 96px;
    overflow-y: auto;
    font-family: var(--font-mono);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 8px 10px;
  }
  #log[hidden] { display: none; }

  /* ── Header controls ─────────────────────────────────────────────── */
  #gearBtn {
    background: none;
    border: 1px solid var(--border);
    color: var(--text);
    width: 44px;
    height: 44px;
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    flex: 0 0 auto;
    transition: background 0.12s, border-color 0.12s, color 0.12s;
  }
  #gearBtn svg { width: 20px; height: 20px; }
  #gearBtn:hover { background: var(--surface); border-color: color-mix(in srgb, var(--accent) 40%, var(--border)); color: var(--accent); }

  #settingsOverlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.55);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
    z-index: 9;
  }
  #settingsOverlay.open { opacity: 1; pointer-events: auto; }
  #settingsPanel {
    position: fixed;
    top: 0;
    right: 0;
    height: 100%;
    width: min(340px, 100%);
    background: var(--surface);
    border-left: 1px solid var(--border);
    box-shadow: -8px 0 32px rgba(0, 0, 0, 0.4);
    padding: 16px;
    transform: translateX(100%);
    transition: transform 0.2s ease;
    z-index: 10;
    overflow-y: auto;
  }
  #settingsPanel.open { transform: translateX(0); }
  #settingsPanel .panelHead {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 4px;
  }
  #settingsPanel h2 { font-size: 15px; margin: 0; font-weight: 700; }
  #settingsCloseBtn {
    background: none;
    border: 1px solid var(--border);
    color: var(--text);
    width: 44px;
    height: 44px;
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    flex: 0 0 auto;
  }
  #settingsCloseBtn svg { width: 18px; height: 18px; }
  #settingsCloseBtn:hover { background: var(--bg); border-color: color-mix(in srgb, var(--accent) 40%, var(--border)); color: var(--accent); }
  #settingsPanel .label {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--text-muted);
    margin: 18px 0 6px;
  }
  #brainStatus { font-size: 12px; color: var(--text-muted); }
  .brainOption {
    display: flex;
    align-items: center;
    gap: 10px;
    min-height: 44px;
    padding: 5px 4px;
    border-radius: var(--radius-sm);
    cursor: pointer;
  }
  .brainOption:hover { background: var(--bg); }
  .brainOption input { margin: 0; flex: 0 0 auto; width: 18px; height: 18px; accent-color: var(--accent); }
  .brainOption label { font-size: 14px; cursor: pointer; flex: 1 1 auto; }
  .brainOption.disabled { cursor: not-allowed; }
  .brainOption.disabled:hover { background: none; }
  .brainOption.disabled label { color: var(--text-muted); cursor: not-allowed; }
  #personaInput {
    width: 100%;
    min-height: 80px;
    background: var(--bg);
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 8px;
    font: 13px/1.4 inherit;
    resize: vertical;
  }
  #voiceSelect {
    width: 100%;
    min-height: 44px;
    background: var(--bg);
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 8px;
    font: 13px/1.4 inherit;
  }
  .panelBtn {
    width: 100%;
    min-height: 44px;
    padding: 8px;
    margin-top: 8px;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--bg);
    color: var(--text);
    font-size: 13px;
    cursor: pointer;
  }
  .panelBtn:hover { background: var(--border); }
  .panelBtn.primary { background: var(--accent); border-color: var(--accent); color: #05161a; font-weight: 700; }
  .panelBtn.primary:hover { background: color-mix(in srgb, var(--accent) 85%, white); }

  @media (prefers-reduced-motion: reduce) {
    #statusText.shimmer, .pttPulse, #ptt.recording .pttPulse, .wbar, .card { animation: none !important; transition: none !important; }
  }

  /* ── Hi-Fi component fidelity: analog VU meter, machined keycap, LCD strips ──
     Ref: themes/_refs/hifi-mobile.html + comp-A-hifi.png. All 23 tokens above
     are unchanged — everything here is additive, keyed off --level, and uses
     the shared mount points (#meterChrome, .panelFrame, #pttDeco). */
  [data-theme="hifi"] body {
    background: linear-gradient(135deg, color-mix(in srgb, var(--bg) 94%, white 6%) 0%, var(--bg) 60%),
                repeating-linear-gradient(0deg, rgba(255,255,255,0.02) 0px, rgba(255,255,255,0.02) 1px, transparent 1px, transparent 2px);
  }
  [data-theme="hifi"] #dot {
    box-shadow: inset 0 0 2px rgba(0,0,0,0.6), 0 0 0 1px rgba(0,0,0,0.4);
  }
  [data-theme="hifi"] #dot.connected { box-shadow: inset 0 0 2px rgba(0,0,0,0.3), 0 0 8px color-mix(in srgb, var(--ok) 70%, transparent), 0 0 0 1px rgba(0,0,0,0.4); }
  [data-theme="hifi"] #dot.connecting { box-shadow: inset 0 0 2px rgba(0,0,0,0.3), 0 0 8px color-mix(in srgb, var(--warn) 70%, transparent), 0 0 0 1px rgba(0,0,0,0.4); }
  [data-theme="hifi"] #dot.error { box-shadow: inset 0 0 2px rgba(0,0,0,0.3), 0 0 8px color-mix(in srgb, var(--bad) 70%, transparent), 0 0 0 1px rgba(0,0,0,0.4); }

  /* Cards as backlit dot-matrix/LCD strips */
  [data-theme="hifi"] .card {
    position: relative;
    overflow: hidden;
    background: linear-gradient(180deg, color-mix(in srgb, var(--bg) 70%, black) 0%, var(--surface) 100%);
    box-shadow: var(--shadow-card), inset 0 2px 6px rgba(0,0,0,0.55), inset 0 0 0 1px rgba(0,0,0,0.35);
  }
  [data-theme="hifi"] .card::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(0deg, rgba(255,255,255,0.025) 0px, rgba(255,255,255,0.025) 1px, transparent 1px, transparent 2px);
    pointer-events: none;
  }
  [data-theme="hifi"] .card .label { color: color-mix(in srgb, var(--text) 55%, var(--surface-2)); }
  [data-theme="hifi"] .card .body {
    position: relative;
    color: #E8C878;
    font-family: var(--font-mono);
    text-shadow: 0 0 6px rgba(232,200,120,0.35);
  }
  [data-theme="hifi"] #assistantText .body { color: var(--accent); text-shadow: 0 0 8px color-mix(in srgb, var(--accent) 55%, transparent); }

  /* .panelFrame: brushed panel edge + corner screws */
  [data-theme="hifi"] .card, [data-theme="hifi"] #historyRail, [data-theme="hifi"] #sessionRail {
    position: relative;
  }
  [data-theme="hifi"] .panelFrame {
    display: block;
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.05), inset 0 0 0 1px rgba(0,0,0,0.5);
  }
  [data-theme="hifi"] .panelFrame::before,
  [data-theme="hifi"] .panelFrame::after {
    content: "";
    position: absolute;
    width: 4px; height: 4px;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 35%, color-mix(in srgb, var(--text) 40%, var(--surface-2)), var(--bg));
    box-shadow: 0 1px 1px rgba(0,0,0,0.6);
  }
  [data-theme="hifi"] .panelFrame::before { top: 6px; left: 6px; }
  [data-theme="hifi"] .panelFrame::after { bottom: 6px; right: 6px; }

  /* #meterChrome: analog VU face + needle, replaces the bar waveform */
  [data-theme="hifi"] .waveform { display: none; }
  [data-theme="hifi"] #meterChrome {
    display: block;
    position: relative;
    width: 220px;
    max-width: 90%;
    height: 84px;
    margin: 0 auto 2px;
  }
  [data-theme="hifi"] .meterFace {
    position: absolute;
    inset: 0;
    display: block;
    background: radial-gradient(ellipse at 50% 130%, #F7F1DD 0%, #EDE3C4 55%, #D9CBA0 100%);
    border-radius: 10px 10px 90px 90px / 10px 10px 54px 54px;
    box-shadow: inset 0 2px 4px rgba(0,0,0,0.35), inset 0 -1px 0 rgba(255,255,255,0.4), 0 3px 8px rgba(0,0,0,0.5);
    border: 2px solid #8b7d5c;
    transition: box-shadow 0.15s ease;
  }
  [data-theme="hifi"] #ptt.recording ~ #meterChrome .meterFace {
    box-shadow: inset 0 2px 4px rgba(0,0,0,0.35), inset 0 -1px 0 rgba(255,255,255,0.4), 0 0 18px color-mix(in srgb, var(--rec) 55%, transparent), 0 3px 8px rgba(0,0,0,0.5);
  }
  [data-theme="hifi"] .meterTicks {
    display: block;
    position: absolute;
    left: 12%; right: 12%; top: 16px; height: 1px;
    background-image: repeating-linear-gradient(90deg, #6b5f45 0 2px, transparent 2px 20px);
    opacity: 0.55;
  }
  [data-theme="hifi"] .meterTicks::after {
    content: "-20    -10    0    +3";
    position: absolute;
    top: 8px; left: 0; right: 0;
    font-family: var(--font-mono);
    font-size: 8px;
    letter-spacing: 0.1em;
    color: #6b5f45;
    text-align: justify;
    white-space: nowrap;
  }
  [data-theme="hifi"] .meterNeedle {
    display: block;
    position: absolute;
    left: 50%; bottom: 8px;
    width: 2px; height: 56px;
    background: linear-gradient(#B23B2E, #7a271d);
    border-radius: 2px 2px 0 0;
    transform-origin: bottom center;
    transform: rotate(calc(-45deg + var(--level, 0) * 90deg));
    transition: transform 0.12s cubic-bezier(.2,1.4,.4,1);
    box-shadow: 0 0 4px rgba(178,59,46,0.6);
  }
  [data-theme="hifi"] .meterNeedle::after {
    content: "";
    position: absolute;
    bottom: -5px; left: 50%;
    width: 10px; height: 10px;
    transform: translateX(-50%);
    border-radius: 50%;
    background: radial-gradient(circle, #3a3530, var(--bg));
    box-shadow: 0 1px 2px rgba(0,0,0,0.6);
  }

  /* #pttDeco: machined keycap orange indicator slot */
  [data-theme="hifi"] #ptt {
    background: linear-gradient(160deg, color-mix(in srgb, var(--surface-2) 70%, white 8%) 0%, var(--surface) 55%, var(--bg) 100%);
    border: 1px solid rgba(255,247,224,0.14);
  }
  [data-theme="hifi"] #pttDeco {
    display: block;
    position: absolute;
    top: 15%;
    left: 50%;
    width: 8px;
    height: 18px;
    transform: translateX(-50%);
    border-radius: 2px;
    background: color-mix(in srgb, var(--surface-2) 60%, black 15%);
    box-shadow: inset 0 1px 2px rgba(0,0,0,0.6);
    pointer-events: none;
  }
  [data-theme="hifi"] #pttDeco::after {
    content: "";
    position: absolute;
    inset: 2px;
    border-radius: 1px;
    background: var(--accent);
    opacity: 0.35;
    transition: opacity 0.15s ease, background 0.15s ease, box-shadow 0.15s ease;
  }
  [data-theme="hifi"] #ptt.recording #pttDeco::after {
    background: var(--rec);
    opacity: 1;
    box-shadow: 0 0 8px var(--rec);
  }

  /* ── Console component fidelity: module-grid etching, segment-bar meter,
     orange push button, recessed light panels ──
     Ref: themes/_refs/rams-mobile.html + comp-D-rams.png. All 23 tokens above
     are unchanged — everything here is additive and uses the shared mount
     points (.panelFrame, #pttDeco); the segment meter reuses the existing
     .wbar bars per THEME-SPEC guidance (no new mount point needed). */
  [data-theme="console"] .card {
    position: relative;
    background: linear-gradient(180deg, var(--surface) 0%, color-mix(in srgb, var(--surface) 90%, black) 100%);
  }
  [data-theme="console"] .card .label,
  [data-theme="console"] #historyRail .label,
  [data-theme="console"] #sessionRail .label {
    font-family: var(--font-display);
    font-size: 9px;
    letter-spacing: 0.16em;
    display: flex;
    align-items: center;
    gap: 6px;
    padding-bottom: 6px;
    border-bottom: 1px solid var(--border);
  }
  [data-theme="console"] .card .label::after,
  [data-theme="console"] #historyRail .label::after,
  [data-theme="console"] #sessionRail .label::after {
    content: "";
    flex: 1 1 auto;
    height: 1px;
    background-image: repeating-linear-gradient(90deg, var(--border) 0 2px, transparent 2px 5px);
  }

  /* Recessed light panels for transcript/assistant bodies */
  [data-theme="console"] .card .body {
    background: color-mix(in srgb, var(--bg) 88%, black 4%);
    border-radius: var(--radius-sm);
    padding: 10px 12px;
    margin-top: 2px;
    box-shadow: inset 0 2px 5px rgba(30,28,22,0.2), inset 0 0 0 1px rgba(30,28,22,0.08);
    font-family: var(--font-mono);
  }

  /* .panelFrame: corner toggle-switch nub (module-grid ornament) */
  [data-theme="console"] .card, [data-theme="console"] #historyRail, [data-theme="console"] #sessionRail {
    position: relative;
  }
  [data-theme="console"] .panelFrame {
    display: block;
    position: absolute;
    top: 10px;
    right: 10px;
    width: 24px;
    height: 10px;
    border-radius: 5px;
    background: var(--surface-2);
    box-shadow: inset 0 1px 2px rgba(30,28,22,0.28);
    pointer-events: none;
  }
  [data-theme="console"] .panelFrame::after {
    content: "";
    position: absolute;
    top: 1px; left: 1px;
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--text-muted);
    box-shadow: 0 1px 1px rgba(0,0,0,0.35);
  }

  /* Segment-bar level meter: restyle the existing .wbar bars as discrete blocks */
  [data-theme="console"] .wbar {
    background-color: var(--surface-2);
    background-image: repeating-linear-gradient(0deg, var(--accent) 0px, var(--accent) 3px, transparent 3px, transparent 5px);
    box-shadow: inset 0 0 0 1px var(--border);
    border-radius: 2px;
    max-width: 11px;
    opacity: 1;
  }
  [data-theme="console"] #ptt.recording ~ #waveform .wbar {
    background-image: repeating-linear-gradient(0deg, var(--rec) 0px, var(--rec) 3px, transparent 3px, transparent 5px);
  }

  /* #pttDeco: recessed ring around the bright orange push button + status lamp */
  [data-theme="console"] #ptt {
    background: radial-gradient(circle at 35% 30%, color-mix(in srgb, var(--accent) 55%, white 10%), var(--accent) 72%);
  }
  [data-theme="console"] #ptt.recording {
    background: radial-gradient(circle at 35% 30%, color-mix(in srgb, var(--rec) 55%, white 10%), var(--rec) 72%);
  }
  [data-theme="console"] #ptt:active {
    transform: translateY(1px) scale(0.97);
    box-shadow: inset 0 3px 6px rgba(0,0,0,0.25);
  }
  [data-theme="console"] #pttDeco {
    display: block;
    position: absolute;
    inset: 10px;
    border-radius: 50%;
    border: 3px solid rgba(30,28,22,0.16);
    box-shadow: inset 0 2px 4px rgba(0,0,0,0.15), inset 0 -1px 0 rgba(255,255,255,0.3);
    pointer-events: none;
  }
  [data-theme="console"] #ptt::before {
    content: "";
    position: absolute;
    top: -14px;
    left: 50%;
    transform: translateX(-50%);
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--text-muted);
    opacity: 0.4;
    box-shadow: inset 0 1px 1px rgba(0,0,0,0.3);
    transition: background 0.15s ease, opacity 0.15s ease, box-shadow 0.15s ease;
  }
  [data-theme="console"] #ptt.recording::before {
    background: var(--rec);
    opacity: 1;
    box-shadow: 0 0 8px var(--rec);
  }
</style>

<svg width="0" height="0" aria-hidden="true" style="position:absolute">
  <defs>
    <filter id="vaMist" x="-20%" y="-20%" width="140%" height="140%">
      <feTurbulence type="fractalNoise" baseFrequency="0.006 0.012" numOctaves="2" seed="7" result="vaMistNoise"/>
      <feDisplacementMap in="SourceGraphic" in2="vaMistNoise" scale="40" xChannelSelector="R" yChannelSelector="G"/>
      <feGaussianBlur stdDeviation="18"/>
    </filter>
  </defs>
</svg>
<div id="fxBack" aria-hidden="true"></div>

<header>
  <h1>Voice Client</h1>
  <div id="status"><span id="dot"></span><span id="statusText">idle</span></div>
  <button id="gearBtn" title="Settings" aria-label="Settings">
    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M12 15.5a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7Z" stroke="currentColor" stroke-width="1.6"/>
      <path d="M19.4 13a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V19a2 2 0 1 1-4 0v-.09a1.65 1.65 0 0 0-1.08-1.51 1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H4a2 2 0 1 1 0-4h.09A1.65 1.65 0 0 0 5.6 9.6a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H10a1.65 1.65 0 0 0 1-1.51V4a2 2 0 1 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V10a1.65 1.65 0 0 0 1.51 1H20a2 2 0 1 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1Z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>
</header>

<div id="gateBanner" hidden role="alert" aria-live="assertive" aria-atomic="true">
  <div class="gateBannerInner">
    <div id="gateDesc" class="gateDesc"></div>
    <span id="gateMore" class="gateMore"></span>
    <div class="gateControls">
      <button type="button" id="gateDeny" class="gateDenyBtn">Deny</button>
      <div id="gateApprove" class="gateHold" tabindex="0" role="button" aria-label="Hold to approve">
        <div id="gateApproveFill" class="gateHoldFill"></div>
        <span class="gateHoldLabel">Hold to approve</span>
      </div>
    </div>
  </div>
</div>

<div id="bannerMount" aria-hidden="true"></div>

<div id="settingsOverlay"></div>
<aside id="settingsPanel">
  <div class="panelHead">
    <h2>Settings</h2>
    <button id="settingsCloseBtn" title="Close" aria-label="Close settings">
      <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>
  </div>
  <div class="label">Theme</div>
  <div id="themeSwatches"></div>
  <div id="brainStatus">—</div>
  <div class="label">Brain</div>
  <div id="brainList"></div>
  <div class="label">Persona</div>
  <textarea id="personaInput" placeholder="Leave empty to restore default persona"></textarea>
  <div class="label" id="voiceLabel" hidden>Voice</div>
  <select id="voiceSelect" hidden></select>
  <button class="panelBtn primary" id="applyPersonaBtn">Apply</button>
  <button class="panelBtn" id="resetChatBtn">Reset chat</button>
  <div class="panelFrame" aria-hidden="true"></div>
</aside>

<div id="contentGrid">
  <aside id="historyRail">
    <div class="label">History</div>
    <div id="historyList"></div>
    <div class="panelFrame" aria-hidden="true"></div>
  </aside>

  <main>
    <div id="avatarPane">
      <div id="avatarMount" aria-hidden="true"></div>
      <div id="avatarFallback" hidden></div>
      <button type="button" id="avatarToggle" aria-label="Collapse avatar" aria-expanded="true">
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <div class="panelFrame" aria-hidden="true"></div>
    </div>
    <div class="card" id="transcript">
      <div class="label">You said</div>
      <div class="body" id="transcriptBody">—</div>
      <div class="panelFrame" aria-hidden="true"></div>
    </div>
    <div class="card" id="assistantText">
      <div class="label">Assistant</div>
      <div class="body" id="assistantBody">—</div>
      <div class="panelFrame" aria-hidden="true"></div>
    </div>

    <div id="pttWrap">
      <div class="statCol" id="statColL" aria-hidden="true"></div>
      <button id="ptt" disabled aria-label="Hold to talk">
        <span class="pttPulse" aria-hidden="true"></span>
        <span id="pttDeco" aria-hidden="true">
          <i aria-hidden="true"></i>
          <i aria-hidden="true"></i>
          <i aria-hidden="true"></i>
          <i aria-hidden="true"></i>
          <i aria-hidden="true"></i>
          <i aria-hidden="true"></i>
          <i aria-hidden="true"></i>
          <i aria-hidden="true"></i>
        </span>
        <svg class="pttIcon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M12 15a3 3 0 0 0 3-3V6a3 3 0 0 0-6 0v6a3 3 0 0 0 3 3Z" fill="currentColor"/>
          <path d="M19 11a1 1 0 1 0-2 0 5 5 0 0 1-10 0 1 1 0 1 0-2 0 7 7 0 0 0 6 6.93V21H9a1 1 0 1 0 0 2h6a1 1 0 1 0 0-2h-2v-3.07A7 7 0 0 0 19 11Z" fill="currentColor"/>
        </svg>
      </button>
      <div class="statCol" id="statColR" aria-hidden="true"></div>
      <div id="pttCaption">Connecting…</div>
      <div id="meterChrome" aria-hidden="true">
        <span class="meterFace"></span>
        <span class="meterNeedle"></span>
        <span class="meterTicks"></span>
      </div>
      <div class="waveform" id="waveform" aria-hidden="true">
        <span class="wbar"></span>
        <span class="wbar"></span>
        <span class="wbar"></span>
        <span class="wbar"></span>
        <span class="wbar"></span>
        <span class="wbar"></span>
        <span class="wbar"></span>
      </div>
    </div>
    <div class="hint">Hold to talk, or press and hold Space. Release to send.</div>
    <button type="button" class="diagToggle" id="diagToggle">Diagnostics</button>
    <div id="log" hidden></div>
  </main>

  <aside id="sessionRail">
    <div id="questCard" data-cockpit-status="idle" hidden>
      <div class="questHeader">TASK</div>
      <div id="questTask" class="questTaskText" title="">—</div>
      <div id="questStatusLine" class="questStatusLine"></div>
      <div id="questUnreachable" class="questUnreachable" hidden>HERMES UNREACHABLE</div>
      <div id="questSteps" class="questSteps"></div>
      <div id="questResult" class="questResult" hidden></div>
    </div>
    <div class="label">Session</div>
    <div class="sessionRow"><span class="sessionKey">Brain</span><span class="sessionVal" id="sessionBrain">—</span></div>
    <div class="sessionRow"><span class="sessionKey">Voice</span><span class="sessionVal" id="sessionVoice">—</span></div>
    <div class="sessionRow"><span class="sessionKey">Tools</span><span class="sessionVal" id="sessionTools">—</span></div>
    <div class="sessionRow"><span class="sessionKey">Mood</span><span class="sessionVal" id="sessionMood">neutral</span></div>
    <div class="sessionRow"><span class="sessionKey">Connection</span><span class="sessionVal" id="sessionConn">—</span></div>
    <div class="sessionPersona">
      <div class="label">Persona</div>
      <div id="sessionPersonaSnippet">—</div>
    </div>
    <div class="panelFrame" aria-hidden="true"></div>
  </aside>
</div>

<script>
"use strict";

// ── Config ───────────────────────────────────────────────────────────
// Derive ws host at runtime so the SAME page works via LAN IP (desktop)
// and Tailscale MagicDNS name / IP (phone). Never hardcode the host.
const WS_URL = window.location.protocol === "https:" ? `wss://${window.location.hostname}:8443` : `ws://${window.location.hostname}:8765`;
const TARGET_RATE = 16000;
const TAIL_SILENCE_SEC = 1.0; // ~1s of int16 zeros to trip server-side VAD end-of-turn

// ── DOM ──────────────────────────────────────────────────────────────
const els = {
  dot: document.getElementById("dot"),
  statusText: document.getElementById("statusText"),
  ptt: document.getElementById("ptt"),
  pttCaption: document.getElementById("pttCaption"),
  transcript: document.getElementById("transcriptBody"),
  assistant: document.getElementById("assistantBody"),
  assistantCard: document.getElementById("assistantText"),
  avatarPane: document.getElementById("avatarPane"),
  avatarMount: document.getElementById("avatarMount"),
  avatarFallback: document.getElementById("avatarFallback"),
  avatarToggle: document.getElementById("avatarToggle"),
  waveform: document.getElementById("waveform"),
  log: document.getElementById("log"),
  diagToggle: document.getElementById("diagToggle"),
  gearBtn: document.getElementById("gearBtn"),
  settingsOverlay: document.getElementById("settingsOverlay"),
  settingsPanel: document.getElementById("settingsPanel"),
  settingsCloseBtn: document.getElementById("settingsCloseBtn"),
  brainStatus: document.getElementById("brainStatus"),
  brainList: document.getElementById("brainList"),
  personaInput: document.getElementById("personaInput"),
  voiceLabel: document.getElementById("voiceLabel"),
  voiceSelect: document.getElementById("voiceSelect"),
  applyPersonaBtn: document.getElementById("applyPersonaBtn"),
  resetChatBtn: document.getElementById("resetChatBtn"),
  themeSwatches: document.getElementById("themeSwatches"),
  historyList: document.getElementById("historyList"),
  sessionBrain: document.getElementById("sessionBrain"),
  sessionVoice: document.getElementById("sessionVoice"),
  sessionTools: document.getElementById("sessionTools"),
  sessionMood: document.getElementById("sessionMood"),
  sessionConn: document.getElementById("sessionConn"),
  sessionPersonaSnippet: document.getElementById("sessionPersonaSnippet"),
  questCard: document.getElementById("questCard"),
  questTask: document.getElementById("questTask"),
  questStatusLine: document.getElementById("questStatusLine"),
  questUnreachable: document.getElementById("questUnreachable"),
  questSteps: document.getElementById("questSteps"),
  questResult: document.getElementById("questResult"),
  gateBanner: document.getElementById("gateBanner"),
  gateDesc: document.getElementById("gateDesc"),
  gateMore: document.getElementById("gateMore"),
  gateDeny: document.getElementById("gateDeny"),
  gateApprove: document.getElementById("gateApprove"),
  gateApproveFill: document.getElementById("gateApproveFill"),
};

function log(msg) {
  const t = new Date().toLocaleTimeString();
  els.log.textContent = `[${t}] ${msg}\n` + els.log.textContent;
}
function setStatus(state, text) {
  els.dot.className = state;          // "", connecting, connected, error
  els.statusText.textContent = text;
  els.statusText.classList.toggle("shimmer", text.indexOf("processing") !== -1);
  if (els.sessionConn) els.sessionConn.textContent = text;
}

// ── Diagnostics (log hidden by default; not persisted) ──────────────
els.diagToggle.addEventListener("click", () => {
  els.log.hidden = !els.log.hidden;
});

// ── Theming ─────────────────────────────────────────────────────────
// Built-ins are pure CSS ([data-theme="..."] blocks already inline in this
// page) — selecting one never triggers a network request. Customs come from
// themes/themes.json + themes/<id>.css; see themes/THEME-SPEC.md.
const BUILTIN_THEMES = [
  { id: "editorial", name: "Editorial", swatch: ["#F5F5F0", "#1A1A1A"] },
  { id: "console", name: "Console", swatch: ["#E7E3D8", "#E8590C"] },
  { id: "hifi", name: "Hi-Fi", swatch: ["#17140F", "#EA6B1E"] },
];
const BUILTIN_THEME_IDS = new Set(BUILTIN_THEMES.map((t) => t.id));
const THEME_ID_RE = /^[a-z0-9-]+$/;
let customThemes = [];
const loadedThemeLinks = new Set();

function setTheme(id) {
  const custom = customThemes.find((t) => t.id === id);
  if (!BUILTIN_THEME_IDS.has(id) && !custom) {
    console.warn(`setTheme: refusing unknown/unvalidated theme id "${id}"`);
    return;
  }
  if (custom && !loadedThemeLinks.has(id)) {
    const link = document.createElement("link");
    link.rel = "stylesheet";
    link.href = `themes/${id}.css`;
    document.head.appendChild(link);
    loadedThemeLinks.add(id);
  }
  document.documentElement.setAttribute("data-theme", id);
  try { localStorage.setItem("va-theme", id); } catch {}
  renderThemeSwatches();
}

function renderThemeSwatches() {
  if (!els.themeSwatches) return;
  const active = document.documentElement.getAttribute("data-theme");
  const all = BUILTIN_THEMES.concat(customThemes);
  els.themeSwatches.innerHTML = "";
  all.forEach((t) => {
    const btn = document.createElement("button");
    btn.type = "button";
    btn.className = "themeSwatch" + (t.id === active ? " active" : "");
    btn.setAttribute("aria-label", t.name);
    const dot = document.createElement("span");
    dot.className = "swatchDot";
    const c1 = (t.swatch && t.swatch[0]) || "#888";
    const c2 = (t.swatch && t.swatch[1]) || "#444";
    dot.style.background = `linear-gradient(135deg, ${c1} 50%, ${c2} 50%)`;
    const name = document.createElement("span");
    name.className = "swatchName";
    name.textContent = t.name || t.id;
    btn.appendChild(dot);
    btn.appendChild(name);
    btn.addEventListener("click", () => setTheme(t.id));
    els.themeSwatches.appendChild(btn);
  });
}

async function loadCustomThemes() {
  try {
    const res = await fetch("themes/themes.json");
    if (res.ok) {
      const data = await res.json();
      if (Array.isArray(data)) {
        customThemes = data.filter((t) => {
          const ok = !!t && typeof t.id === "string" && THEME_ID_RE.test(t.id);
          if (!ok) console.warn("loadCustomThemes: dropping invalid theme manifest entry", t);
          return ok;
        });
      }
    }
  } catch {
    // no manifest yet, or offline — built-ins only, fail silently
  }
  renderThemeSwatches();
  // Boot may have saved a custom id before the manifest loaded; apply it now.
  let saved = null;
  try { saved = localStorage.getItem("va-theme"); } catch {}
  if (saved && customThemes.some((t) => t.id === saved) && document.documentElement.getAttribute("data-theme") !== saved) {
    setTheme(saved);
  }
}
renderThemeSwatches();
loadCustomThemes();

// ── Conversation history (left rail, additive, in-memory only) ──────
const HISTORY_CAP = 50;
let conversationHistory = [];
let pendingHistoryEntry = null;

function renderHistory() {
  if (!els.historyList) return;
  els.historyList.innerHTML = "";
  conversationHistory.forEach((entry) => {
    const row = document.createElement("div");
    row.className = "historyEntry";
    const time = document.createElement("div");
    time.className = "historyTime";
    time.textContent = entry.time;
    const user = document.createElement("div");
    user.className = "historyUser";
    user.textContent = entry.user;
    const assistant = document.createElement("div");
    assistant.className = "historyAssistant";
    assistant.textContent = entry.assistant;
    row.appendChild(time);
    row.appendChild(user);
    row.appendChild(assistant);
    els.historyList.appendChild(row);
  });
}

function pushHistoryEntry(entry) {
  conversationHistory.unshift(entry);
  if (conversationHistory.length > HISTORY_CAP) conversationHistory.length = HISTORY_CAP;
  renderHistory();
}

// ── Session rail (right rail, read-only mirror of config_state/status) ──
let lastKnownModel = null;

function updateSessionRail(ev, active) {
  if (els.sessionBrain) {
    const label = active ? active.label : (ev.active_brain || "—");
    els.sessionBrain.textContent = label + (lastKnownModel ? ` · ${lastKnownModel}` : "");
  }
  if (els.sessionVoice) {
    els.sessionVoice.textContent = ev.voice || "—";
  }
  if (els.sessionTools) {
    const tools = typeof ev.tools_armed === "number" ? ev.tools_armed : null;
    els.sessionTools.textContent = tools === null ? "—" : `${tools} armed`;
  }
  if (els.sessionPersonaSnippet) {
    const p = (ev.persona || "").trim();
    els.sessionPersonaSnippet.textContent = p ? (p.length > 140 ? p.slice(0, 140) + "…" : p) : "Default persona";
  }
}

// ── Cockpit: quest card + approval gate (pure render of cockpit_state) ──
// No client-side accumulation — every render works from the latest snapshot
// only, so a page refresh or ws reconnect is always render-safe.
const QUEST_STATUS_LABELS = { idle: "Idle", sent: "Sent", running: "Running", done: "Done", error: "Error" };
let cockpitState = null;
let questTickerId = null;
let gateRespondedId = null; // id we've already sent a permission_respond for; cleared once the server's next snapshot moves on

function fmtElapsed(startedTs) {
  const secs = Math.max(0, Math.floor(Date.now() / 1000 - startedTs));
  const m = Math.floor(secs / 60), s = secs % 60;
  return m > 0 ? `${m}m ${s}s` : `${s}s`;
}

function updateQuestStatusLine() {
  if (!cockpitState) return;
  const d = cockpitState.delegation || {};
  let text = QUEST_STATUS_LABELS[d.status] || d.status || "";
  if (d.active && d.started_ts) text += ` · ${fmtElapsed(d.started_ts)}`;
  els.questStatusLine.textContent = text;
}

function renderQuestSteps(steps) {
  els.questSteps.innerHTML = "";
  (steps || []).forEach((s) => {
    const row = document.createElement("div");
    row.className = "questStep";
    const role = document.createElement("span");
    role.className = "questStepRole";
    role.textContent = s.role || "";
    const text = document.createElement("span");
    text.className = "questStepText";
    text.textContent = s.text || "";
    row.appendChild(role);
    row.appendChild(text);
    els.questSteps.appendChild(row);
  });
  els.questSteps.scrollTop = els.questSteps.scrollHeight; // newest visible
}

function renderQuestCard(state) {
  const d = state.delegation || {};
  const perms = Array.isArray(state.permissions) ? state.permissions : [];
  const show = d.status !== "idle" || perms.length > 0;
  els.questCard.hidden = !show;
  els.questCard.dataset.cockpitStatus = d.status || "idle";
  if (!show) {
    if (questTickerId) { clearInterval(questTickerId); questTickerId = null; }
    return;
  }

  const task = d.task || "";
  els.questTask.textContent = task ? (task.length > 100 ? task.slice(0, 100) + "…" : task) : "—";
  els.questTask.title = task;

  updateQuestStatusLine();
  if (d.active && !questTickerId) {
    questTickerId = setInterval(updateQuestStatusLine, 1000);
  } else if (!d.active && questTickerId) {
    clearInterval(questTickerId);
    questTickerId = null;
  }

  els.questUnreachable.hidden = state.hermes_ok !== false;
  renderQuestSteps(d.steps);

  const hasResult = d.status === "done" || d.status === "error";
  els.questResult.hidden = !hasResult;
  if (hasResult) els.questResult.textContent = d.result != null ? String(d.result) : "—";
}

// Permission object shape beyond `id` is server-defined and untrusted — render
// defensively, textContent only, never innerHTML.
function permissionSummary(p) {
  for (const key of ["summary", "title", "description", "tool", "action"]) {
    if (typeof p[key] === "string" && p[key]) return p[key];
  }
  try {
    const s = JSON.stringify(p);
    return s.length > 120 ? s.slice(0, 120) + "…" : s;
  } catch {
    return String(p);
  }
}

function setGateControlsEnabled(enabled) {
  els.gateApprove.setAttribute("aria-disabled", enabled ? "false" : "true");
  els.gateApprove.tabIndex = enabled ? 0 : -1;
  els.gateDeny.disabled = !enabled;
  if (!enabled) cancelGateHold();
}

function renderGateBanner(perms) {
  const has = perms.length > 0;
  els.gateBanner.hidden = !has;
  if (!has) {
    gateRespondedId = null;
    cancelGateHold();
    resetGateFillIfStale();
    return;
  }
  const first = perms[0];
  const id = first && first.id;
  if (gateRespondedId !== null && String(id) !== String(gateRespondedId)) {
    gateRespondedId = null; // server moved on to a different (or repeated) permission
  }
  // The displayed permission changed under the user's finger — the server
  // would reject a stale id anyway, but the in-progress hold must abort
  // rather than silently keep counting toward a permission that's no
  // longer shown.
  if (holdRAF && String(id) !== String(holdPermId)) {
    cancelGateHold();
  }
  const idLabel = id !== undefined && id !== null ? ` (#${id})` : "";
  els.gateDesc.textContent = permissionSummary(first) + idLabel;
  els.gateMore.textContent = perms.length > 1 ? `and ${perms.length - 1} more` : "";
  const enabled = gateRespondedId === null;
  setGateControlsEnabled(enabled);
  if (enabled) resetGateFillIfStale();
}

function renderCockpit(state) {
  cockpitState = state;
  renderQuestCard(state);
  renderGateBanner(Array.isArray(state.permissions) ? state.permissions : []);
}

// ── Approval gate: hold-to-approve (1.5s) / single-click deny ───────────
const GATE_HOLD_MS = 1500;
let holdRAF = null;
let holdStartTime = 0;
let holdCompleted = false;
let holdPermId = null; // id the in-progress (or just-completed) hold is tracking

function currentGatePermission() {
  return cockpitState && Array.isArray(cockpitState.permissions) ? cockpitState.permissions[0] : null;
}

function sendPermissionRespond(id, approve) {
  if (ws && ws.readyState === WebSocket.OPEN) {
    ws.send(JSON.stringify({ type: "config_set", permission_respond: { id, approve } }));
  }
}

function cancelGateHold() {
  if (holdCompleted) return; // leave the completed (100%) fill in place until the next snapshot re-renders
  if (holdRAF) cancelAnimationFrame(holdRAF);
  holdRAF = null;
  holdPermId = null;
  els.gateApprove.classList.remove("holding");
  els.gateApproveFill.style.setProperty("--hold-progress", "0");
}

// Clears a completed hold's stuck 100% fill once a render moves on to a
// state where controls are being (re)enabled — cancelGateHold() alone can't
// do this because it deliberately no-ops while holdCompleted is true.
function resetGateFillIfStale() {
  if (holdRAF) return; // an active hold is in progress — leave it alone
  if (!holdCompleted) return;
  holdCompleted = false;
  holdPermId = null;
  els.gateApprove.classList.remove("holding");
  els.gateApproveFill.style.setProperty("--hold-progress", "0");
}

function completeGateHold(id) {
  holdCompleted = true;
  holdRAF = null;
  holdPermId = null;
  els.gateApprove.classList.remove("holding");
  els.gateApproveFill.style.setProperty("--hold-progress", "1");
  gateRespondedId = id;
  setGateControlsEnabled(false);
  sendPermissionRespond(id, true);
}

function startGateHold() {
  if (els.gateApprove.getAttribute("aria-disabled") === "true" || holdRAF) return;
  const perm = currentGatePermission();
  if (!perm) return;
  holdCompleted = false;
  holdPermId = perm.id;
  holdStartTime = performance.now();
  els.gateApprove.classList.add("holding");
  const tick = (now) => {
    const pct = Math.min(1, (now - holdStartTime) / GATE_HOLD_MS);
    els.gateApproveFill.style.setProperty("--hold-progress", pct.toFixed(3));
    if (pct >= 1) { completeGateHold(perm.id); return; }
    holdRAF = requestAnimationFrame(tick);
  };
  holdRAF = requestAnimationFrame(tick);
}

els.gateApprove.addEventListener("pointerdown", (e) => { e.preventDefault(); startGateHold(); });
["pointerup", "pointercancel", "pointerleave"].forEach((evt) => els.gateApprove.addEventListener(evt, cancelGateHold));
els.gateApprove.addEventListener("keydown", (e) => {
  if (e.key !== "Enter" || e.repeat) return;
  e.preventDefault();
  startGateHold();
});
els.gateApprove.addEventListener("keyup", (e) => {
  if (e.key !== "Enter") return;
  cancelGateHold();
});

let denyGuard = false;
els.gateDeny.addEventListener("click", () => {
  if (denyGuard || els.gateDeny.disabled) return;
  const perm = currentGatePermission();
  if (!perm) return;
  denyGuard = true;
  setTimeout(() => { denyGuard = false; }, 300);
  gateRespondedId = perm.id;
  setGateControlsEnabled(false);
  sendPermissionRespond(perm.id, false);
});

// ── Settings panel (brain + persona control) ───────────────────────────
function openSettings() {
  els.settingsPanel.classList.add("open");
  els.settingsOverlay.classList.add("open");
}
function closeSettings() {
  els.settingsPanel.classList.remove("open");
  els.settingsOverlay.classList.remove("open");
}
els.gearBtn.addEventListener("click", () => {
  els.settingsPanel.classList.contains("open") ? closeSettings() : openSettings();
});
els.settingsOverlay.addEventListener("click", closeSettings);
els.settingsCloseBtn.addEventListener("click", closeSettings);

function renderConfigState(ev) {
  const active = ev.brains.find((b) => b.name === ev.active_brain);
  els.brainStatus.textContent = `Active: ${active ? active.label : ev.active_brain}`;

  els.brainList.innerHTML = "";
  ev.brains.forEach((b) => {
    const row = document.createElement("div");
    row.className = "brainOption" + (b.available ? "" : " disabled");
    const id = "brain_" + b.name;
    const input = document.createElement("input");
    input.type = "radio";
    input.name = "brain";
    input.id = id;
    input.value = b.name;
    input.checked = b.name === ev.active_brain;
    input.disabled = !b.available;
    input.addEventListener("change", () => {
      if (input.checked && ws && ws.readyState === WebSocket.OPEN) {
        ws.send(JSON.stringify({ type: "config_set", brain: b.name }));
      }
    });
    const label = document.createElement("label");
    label.htmlFor = id;
    label.textContent = b.label + (b.note ? ` — ${b.note}` : "");
    row.appendChild(input);
    row.appendChild(label);
    // Whole row is a tap target ≥44px tall; clicks on the input/label already
    // toggle natively via htmlFor, this just extends that to the row's padding.
    row.addEventListener("click", (e) => {
      if (e.target === input || e.target === label || input.disabled) return;
      input.click();
    });
    els.brainList.appendChild(row);
  });

  // Don't clobber text the user is actively editing.
  if (document.activeElement !== els.personaInput) {
    els.personaInput.value = ev.persona || "";
  }

  const voices = ev.voices || [];
  const hasVoices = voices.length > 0;
  els.voiceLabel.hidden = !hasVoices;
  els.voiceSelect.hidden = !hasVoices;
  if (hasVoices && document.activeElement !== els.voiceSelect) {
    els.voiceSelect.innerHTML = "";
    voices.forEach((name) => {
      const opt = document.createElement("option");
      opt.value = name;
      opt.textContent = name;
      opt.selected = name === ev.voice;
      els.voiceSelect.appendChild(opt);
    });
  }

  updateSessionRail(ev, active);
}

els.applyPersonaBtn.addEventListener("click", () => {
  if (ws && ws.readyState === WebSocket.OPEN) {
    ws.send(JSON.stringify({ type: "config_set", persona: els.personaInput.value }));
  }
});
els.resetChatBtn.addEventListener("click", () => {
  if (ws && ws.readyState === WebSocket.OPEN) {
    ws.send(JSON.stringify({ type: "config_set", reset_chat: true }));
  }
  document.documentElement.setAttribute("data-mood", "neutral");
  if (els.sessionMood) els.sessionMood.textContent = "neutral";
  window.__avatarMood?.("neutral"); // this handler bypasses applyMoodFromTools — keep the avatar in sync too
});
els.voiceSelect.addEventListener("change", () => {
  if (ws && ws.readyState === WebSocket.OPEN) {
    ws.send(JSON.stringify({ type: "config_set", voice: els.voiceSelect.value }));
  }
});

// ── Wake lock ────────────────────────────────────────────────────────
// Keep the screen on while connected so a mid-conversation dim doesn't kill
// the mic/audio graph. Best-effort: unsupported browsers no-op silently.
let wakeLock = null;
async function acquireWakeLock() {
  try {
    if (navigator.wakeLock) wakeLock = await navigator.wakeLock.request("screen");
  } catch {}
}
function releaseWakeLock() {
  try { wakeLock && wakeLock.release(); } catch {}
  wakeLock = null;
}
document.addEventListener("visibilitychange", () => {
  if (document.visibilityState === "visible" && ws && ws.readyState === WebSocket.OPEN) {
    acquireWakeLock();
  }
});

// ── WebSocket ────────────────────────────────────────────────────────
let ws = null;

function connect() {
  setStatus("connecting", "connecting…");
  els.ptt.disabled = true;
  els.pttCaption.textContent = "Connecting…";

  ws = new WebSocket(WS_URL);
  ws.binaryType = "arraybuffer";

  ws.onopen = () => {
    setStatus("connected", "connected");
    els.ptt.disabled = false;
    els.pttCaption.textContent = "Hold to talk";
    log("ws open " + WS_URL);
    ws.send(JSON.stringify({ type: "config_get" }));
    acquireWakeLock();
  };
  ws.onclose = () => {
    setStatus("error", "disconnected — retrying");
    els.ptt.disabled = true;
    els.pttCaption.textContent = "Reconnecting…";
    log("ws closed; retrying in 2s");
    releaseWakeLock();
    setTimeout(connect, 2000);
  };
  ws.onerror = () => { log("ws error"); };
  ws.onmessage = (ev) => {
    // Mixed types on the same socket: string => JSON PipelineEvent, binary => TTS PCM.
    if (typeof ev.data === "string") {
      handleEvent(ev.data);
    } else {
      // ArrayBuffer (binaryType='arraybuffer'). Int16 16k mono PCM.
      enqueuePlayback(ev.data);
    }
  };
}

const MOOD_VALUES = ["neutral", "happy", "excited", "thinking", "concerned", "playful", "serious"];

function applyMoodFromTools(tools) {
  if (!Array.isArray(tools)) return;
  const call = tools.find((t) => t.name === "set_mood");
  if (!call) return;
  let args = call.arguments;
  if (typeof args === "string") {
    try { args = JSON.parse(args); } catch { args = null; }
  }
  const mood = args && args.mood;
  if (MOOD_VALUES.indexOf(mood) === -1) return;
  document.documentElement.setAttribute("data-mood", mood);
  if (els.sessionMood) els.sessionMood.textContent = mood;
  window.__avatarMood?.(mood); // no-op until the lazy avatar module registers it
}

function handleEvent(text) {
  let ev;
  try { ev = JSON.parse(text); } catch { log("bad json: " + text.slice(0, 120)); return; }
  // NOTE: server discriminator field is `type` (not `event_type`).
  switch (ev.type) {
    case "transcription_completed":
      els.transcript.textContent = ev.transcript || "—";
      if (pendingHistoryEntry) {
        // Barge-in: a new turn started before the previous one got its reply — don't lose it.
        pendingHistoryEntry.assistant = "— (interrupted)";
        pushHistoryEntry(pendingHistoryEntry);
      }
      pendingHistoryEntry = { time: new Date().toLocaleTimeString([], { hour: "2-digit", minute: "2-digit" }), user: ev.transcript || "—", assistant: null };
      break;
    case "assistant_text": {
      const text = ev.text || "";
      els.assistant.textContent = text || "—";
      applyMoodFromTools(ev.tools);
      // Tool-call turns emit an empty-content assistant_text frame before the
      // real answer — skip the history push for that frame so it doesn't log
      // a bare "—" entry; the follow-up frame with actual text fills it in.
      const isToolOnlyFrame = !text && Array.isArray(ev.tools) && ev.tools.length > 0;
      if (!isToolOnlyFrame && pendingHistoryEntry && pendingHistoryEntry.assistant === null) {
        pendingHistoryEntry.assistant = text || "—";
        pushHistoryEntry(pendingHistoryEntry);
        pendingHistoryEntry = null;
      }
      break;
    }
    case "partial_transcription":
      // live partials: show in transcript as it grows
      if (ev.delta) els.transcript.textContent = (els.transcript.textContent === "—" ? "" : els.transcript.textContent) + ev.delta;
      break;
    case "token_usage":
      log(`tokens in=${ev.input_tokens} out=${ev.output_tokens}`);
      break;
    case "config_state":
      renderConfigState(ev);
      break;
    case "cockpit_state":
      renderCockpit(ev);
      break;
    case "config_ack":
      if (ev.permission_respond) {
        const pr = ev.permission_respond;
        log(`permission ${pr.id}: ${pr.approve ? "approved" : "denied"} — ${ev.ok ? "ok" : "failed"}${pr.message ? " (" + pr.message + ")" : ""}`);
        if (!ev.ok) {
          gateRespondedId = null;
          setGateControlsEnabled(true);
        }
        break;
      }
      if (ev.ok) {
        log(`brain=${ev.active_brain} model=${ev.model}`);
        if (ev.model) lastKnownModel = ev.model;
        if (ws && ws.readyState === WebSocket.OPEN) {
          ws.send(JSON.stringify({ type: "config_get" })); // resync panel (brain/persona/reset all land here)
        }
      } else {
        log("config_set failed: " + ev.error);
      }
      break;
    default:
      // speech_started / speech_stopped / etc — keep quiet but traceable
      log("event: " + ev.type);
  }
}

// ── Playback (gapless int16 16k) ─────────────────────────────────────
let playCtx = null;
let nextStartTime = 0;
const liveSources = new Set();
// Optional analysis sink registered by the lazy avatar module (avatar/avatar.mjs)
// for audio-driven lip-sync. Playback path below is otherwise untouched — this
// is purely an ADDITIONAL parallel connection, never a reroute.
let avatarAudioTapNode = null;

function updateSpeakingIndicator() {
  els.assistantCard.classList.toggle("speaking", liveSources.size > 0);
}

function ensurePlayCtx() {
  if (!playCtx) {
    playCtx = new (window.AudioContext || window.webkitAudioContext)({ sampleRate: TARGET_RATE });
  }
  if (playCtx.state === "suspended") playCtx.resume();
  return playCtx;
}

function enqueuePlayback(arrayBuffer) {
  const ctx = ensurePlayCtx();
  const int16 = new Int16Array(arrayBuffer);
  if (int16.length === 0) return;
  const f32 = new Float32Array(int16.length);
  for (let i = 0; i < int16.length; i++) f32[i] = int16[i] / 32768;

  // Buffer is authored at 16k; AudioBufferSourceNode resamples to ctx rate if they differ.
  const buf = ctx.createBuffer(1, f32.length, TARGET_RATE);
  buf.copyToChannel(f32, 0);

  const src = ctx.createBufferSource();
  src.buffer = buf;
  src.connect(ctx.destination);
  if (avatarAudioTapNode) src.connect(avatarAudioTapNode);

  const now = ctx.currentTime;
  if (nextStartTime < now) nextStartTime = now + 0.02; // small priming gap
  src.start(nextStartTime);
  nextStartTime += buf.duration;

  liveSources.add(src);
  updateSpeakingIndicator();
  src.onended = () => { liveSources.delete(src); updateSpeakingIndicator(); };
}

function flushPlayback() {
  // Barge-in: stop everything currently scheduled/playing.
  for (const s of liveSources) { try { s.stop(); } catch {} }
  liveSources.clear();
  nextStartTime = 0;
  updateSpeakingIndicator();
}

// ── Mic capture ──────────────────────────────────────────────────────
// Primary path: AudioContext({sampleRate:16000}) so the graph runs at 16k and
// getUserMedia audio is resampled into it by the browser — no manual resampling,
// worklet just converts Float32→Int16. Fallback: if the browser refuses 16k
// (e.g. Safari ignores the option), the worklet decimates ctx.rate → 16k.
let micStream = null;
let micCtx = null;
let micNode = null;
let capturing = false;   // mic graph is live
let isHeld = false;      // button physically held — the ONLY gate on outbound audio

// Rolling bar-graph waveform driven by the worklet's peak samples.
const wbars = Array.from(els.waveform.querySelectorAll(".wbar"));
const wbarHistory = new Array(wbars.length).fill(0);
let smoothedLevel = 0; // 0..1, lightly smoothed peak — themes drive meter needles/segments off --level
function pushWaveform(peak) {
  wbarHistory.push(Math.max(0.08, Math.min(1, peak * 3.2)));
  wbarHistory.shift();
  wbars.forEach((bar, i) => { bar.style.transform = `scaleY(${wbarHistory[i]})`; });
  smoothedLevel += (Math.max(0, Math.min(1, peak * 3.2)) - smoothedLevel) * 0.35;
  els.waveform.style.setProperty("--level", smoothedLevel.toFixed(3));
  document.documentElement.style.setProperty("--level", smoothedLevel.toFixed(3));
}
function resetWaveform() {
  wbarHistory.fill(0.08);
  wbars.forEach((bar) => { bar.style.transform = "scaleY(0.08)"; });
  smoothedLevel = 0;
  els.waveform.style.setProperty("--level", "0");
  document.documentElement.style.setProperty("--level", "0");
}

// AudioWorklet processor, delivered via Blob so the page stays fully self-contained
// (no external file to fetch — works offline beyond reaching the box).
const WORKLET_SRC = `
class Cap extends AudioWorkletProcessor {
  constructor(opts) {
    super();
    // decimation factor = inputRate / 16000 (1 when context is already 16k)
    this.decim = Math.max(1, Math.round(sampleRate / 16000));
    this._acc = 0;
    this._sum = 0;
    this._count = 0;
    this._out = [];
  }
  process(inputs) {
    const ch = inputs[0] && inputs[0][0];
    if (!ch) return true;
    let peak = 0;
    for (let i = 0; i < ch.length; i++) {
      const v = ch[i];
      const a = v < 0 ? -v : v;
      if (a > peak) peak = a;
      if (this.decim === 1) {
        this._out.push(v);
      } else {
        // box-average decimation (cheap anti-alias) — fine for voice
        this._sum += v;
        this._count++;
        if (this._count >= this.decim) {
          this._out.push(this._sum / this._count);
          this._sum = 0; this._count = 0;
        }
      }
    }
    // flush accumulated samples as Int16 in ~20ms batches (320 samples @16k)
    if (this._out.length >= 320) {
      const n = this._out.length;
      const i16 = new Int16Array(n);
      for (let i = 0; i < n; i++) {
        let s = this._out[i];
        if (s > 1) s = 1; else if (s < -1) s = -1;
        i16[i] = s < 0 ? s * 32768 : s * 32767;
      }
      this._out.length = 0;
      this.port.postMessage({ pcm: i16.buffer, peak }, [i16.buffer]);
    } else {
      this.port.postMessage({ peak });
    }
    return true;
  }
}
registerProcessor('cap', Cap);
`;

async function startCapture() {
  if (capturing) return;
  if (!ws || ws.readyState !== WebSocket.OPEN) { log("not connected"); return; }
  capturing = true;

  // barge-in: kill any assistant audio the moment the user starts talking
  flushPlayback();

  try {
    micStream = await navigator.mediaDevices.getUserMedia({
      audio: { channelCount: 1, echoCancellation: true, noiseSuppression: true, autoGainControl: true },
    });
  } catch (e) {
    capturing = false;
    setStatus("error", "mic denied");
    log("getUserMedia failed: " + e.message);
    return;
  }

  // Released during the mic-permission await? Abort cleanly — never leave a live graph.
  if (!isHeld) { resetWaveform(); teardownMic(); log("released during setup; aborted"); return; }

  // Prefer a 16k context so no resampling is needed.
  try {
    micCtx = new (window.AudioContext || window.webkitAudioContext)({ sampleRate: TARGET_RATE });
  } catch {
    micCtx = new (window.AudioContext || window.webkitAudioContext)();
  }
  if (micCtx.state === "suspended") await micCtx.resume();
  if (micCtx.sampleRate !== TARGET_RATE) {
    log(`ctx rate ${micCtx.sampleRate}Hz → worklet decimates to 16k`);
  }

  const src = micCtx.createMediaStreamSource(micStream);

  const blobUrl = URL.createObjectURL(new Blob([WORKLET_SRC], { type: "application/javascript" }));
  try {
    await micCtx.audioWorklet.addModule(blobUrl);
  } finally {
    URL.revokeObjectURL(blobUrl);
  }

  // Released while the worklet module was loading? Abort — don't wire up a live graph.
  if (!isHeld) { resetWaveform(); teardownMic(); log("released during setup; aborted"); return; }

  micNode = new AudioWorkletNode(micCtx, "cap");
  micNode.port.onmessage = (e) => {
    const d = e.data;
    if (d.peak !== undefined) {
      pushWaveform(d.peak);
    }
    // TRUE push-to-talk: only stream while the button is actively held.
    // Frames produced outside a hold (or after release) are dropped, never sent.
    if (d.pcm && isHeld && ws && ws.readyState === WebSocket.OPEN) {
      ws.send(d.pcm); // raw binary int16 16k mono
    }
  };
  src.connect(micNode);
  // Worklet must be pulled by the graph; connect to a muted gain → destination.
  const sink = micCtx.createGain();
  sink.gain.value = 0;
  micNode.connect(sink);
  sink.connect(micCtx.destination);

  els.ptt.classList.add("recording");
  els.pttCaption.textContent = "Listening… (release to send)";
  setStatus("connected", "recording");
  log("capture start @ " + micCtx.sampleRate + "Hz");
}

// Tear down the mic graph and release the device. Safe to call with partial/null state.
function teardownMic() {
  try { if (micNode) micNode.disconnect(); } catch {}
  try { if (micStream) micStream.getTracks().forEach(t => t.stop()); } catch {}
  try { if (micCtx) micCtx.close(); } catch {}
  micNode = null; micStream = null; micCtx = null;
  capturing = false;
}

async function stopCapture() {
  els.ptt.classList.remove("recording");
  els.pttCaption.textContent = "Hold to talk";
  resetWaveform();
  // If we never actually got a live graph up (very quick tap), there's nothing to
  // flush and no turn to end — just make sure the device is released.
  if (!capturing) { teardownMic(); return; }
  setStatus("connected", "processing…");

  // Send ~1s of int16 zeros to trip the server-side Silero VAD end-of-turn.
  // Server rebuffers into 512-sample chunks, so our frame size is irrelevant —
  // send in ~20ms frames just to mimic the streaming cadence.
  if (ws && ws.readyState === WebSocket.OPEN) {
    const total = Math.floor(TARGET_RATE * TAIL_SILENCE_SEC);
    const frame = 320;
    const zeros = new Int16Array(frame); // reusable zero-filled frame
    for (let i = 0; i < total; i += frame) {
      const n = Math.min(frame, total - i);
      ws.send(n === frame ? zeros.buffer.slice(0) : new Int16Array(n).buffer);
    }
  }

  teardownMic();
  log("capture stop; sent tail silence");
}

// ── PTT button: mouse + touch ────────────────────────────────────────
// isHeld is set SYNCHRONOUSLY here (before the async startCapture runs) and is the
// single source of truth for "should audio be flowing". The worklet gates ws.send on
// it, so no frame can escape unless the button is down at that instant.
const ptt = els.ptt;
function press(e) { e.preventDefault(); isHeld = true; startCapture(); }
function release(e) { if (e) e.preventDefault(); isHeld = false; stopCapture(); }
// Mouse — release on window so dragging off the button still ends the turn.
ptt.addEventListener("mousedown", press);
window.addEventListener("mouseup", release);
// Touch (phone)
ptt.addEventListener("touchstart", press, { passive: false });
ptt.addEventListener("touchend", release, { passive: false });
ptt.addEventListener("touchcancel", release);

// ── Keyboard PTT: hold Space ─────────────────────────────────────────
function isTypingTarget(t) {
  const tag = t && t.tagName;
  return tag === "INPUT" || tag === "TEXTAREA" || tag === "SELECT";
}
window.addEventListener("keydown", (e) => {
  if (e.code !== "Space" || e.repeat) return;
  if (isTypingTarget(e.target) || els.settingsPanel.classList.contains("open")) return;
  if (isHeld) return;
  press(e);
});
window.addEventListener("keyup", (e) => {
  if (e.code !== "Space") return;
  if (!isHeld) return; // no active hold — nothing to do, also keeps textarea spaces normal
  release(e);
});

// ── Avatar pane: lazy, desktop-only (see avatar/avatar.mjs) ───────────
// va-avatar in localStorage is "on" (expanded, default) or "off" (collapsed).
// The heavy module (TalkingHead + HeadAudio + GLB) is only ever dynamically
// imported on desktop AND when the stored state is "on" — collapsing before
// it has ever loaded means zero avatar bytes are fetched at all.
const AVATAR_STORAGE_KEY = "va-avatar";
let avatarController = null; // { start, stop } once avatar.mjs has loaded
function avatarWanted() {
  try { return localStorage.getItem(AVATAR_STORAGE_KEY) !== "off"; } catch { return true; }
}
function isDesktopViewport() { return window.matchMedia("(min-width: 1024px)").matches; }

async function loadAvatarModule() {
  if (avatarController) return;
  try {
    const mod = await import("./avatar/avatar.mjs");
    avatarController = await mod.initAvatar(els.avatarMount, els.avatarFallback, {
      getPlayCtx: ensurePlayCtx,
      setTap: (node) => { avatarAudioTapNode = node; },
    });
  } catch (e) {
    log("avatar module failed to load: " + e.message);
    els.avatarFallback.textContent = "Avatar unavailable";
    els.avatarFallback.hidden = false;
  }
}

// Re-reads avatarWanted() rather than trusting the value captured when the
// (possibly slow, GLB-loading) promise below started — if the user toggles
// again before it resolves, the latest localStorage write wins instead of a
// stale start()/stop() firing after the fact.
function syncAvatarRunState() {
  if (!avatarController) return;
  if (avatarWanted()) avatarController.start();
  else avatarController.stop();
}

function setAvatarWanted(wanted) {
  try { localStorage.setItem(AVATAR_STORAGE_KEY, wanted ? "on" : "off"); } catch {}
  els.avatarPane.classList.toggle("collapsed", !wanted);
  els.avatarToggle.setAttribute("aria-expanded", String(wanted));
  els.avatarToggle.setAttribute("aria-label", wanted ? "Collapse avatar" : "Expand avatar");
  if (wanted) loadAvatarModule().then(syncAvatarRunState);
  else syncAvatarRunState();
}

if (isDesktopViewport()) {
  const wanted = avatarWanted();
  els.avatarPane.classList.toggle("collapsed", !wanted);
  els.avatarToggle.setAttribute("aria-expanded", String(wanted));
  els.avatarToggle.setAttribute("aria-label", wanted ? "Collapse avatar" : "Expand avatar");
  if (wanted) loadAvatarModule().then(syncAvatarRunState);
}
els.avatarToggle.addEventListener("click", () => setAvatarWanted(!avatarWanted()));

// ── Go ───────────────────────────────────────────────────────────────
connect();
</script>
